# Postgres Configuration
POSTGRES_USER=veritas_admin
POSTGRES_PASSWORD=veritas_secure_password
POSTGRES_DB=veritas_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_LOAN_APPS=raw.loan_applications

# Data Source
CSV_FILE_PATH=/app/data/accepted_2007_to_2018Q4.csv

# Airflow Configuration
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://veritas_admin:veritas_secure_password@postgres:5432/veritas_db
AIRFLOW__CORE__FERNET_KEY=  # Generate via: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin_password
